FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && \
    apt-get install -y git && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --upgrade pip && \
    pip install httpx python-dotenv uvicorn && \
    pip install git+https://github.com/modelcontextprotocol/python-sdk.git

COPY .env .env
COPY gotas_mcp_http.py gotas_mcp.py

# Стартувај како HTTP сервер на порта 3000
CMD ["python", "-m", "uvicorn", "gotas_mcp:app", "--host", "0.0.0.0", "--port", "3000"]
